[Unit]
Description=Start docker projects in ~/Desktop/apps
Wants=network-online.target
After=network-online.target docker.service
Requires=docker.service

[Service]
Type=oneshot
ExecStart=/bin/bash /home/piatek/Desktop/apps/configs/startup.sh
RemainAfterExit=yes
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
